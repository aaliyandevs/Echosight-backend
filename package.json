{
  "name": "echosight-backend",
  "version": "0.1.0",
  "private": true,
  "description": "EchoSight backend API (Node.js + TypeScript + MongoDB)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/validators.test.ts tests/name-matcher.test.ts",
    "test:integration": "tsx --test tests/api.integration.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "morgan": "^1.10.0",
    "ws": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "mongodb-memory-server": "^10.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
